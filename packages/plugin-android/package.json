{
  "name": "l10n-tools-plugin-android",
  "version": "7.4.7",
  "description": "l10n-tools plugin for Android platform",
  "type": "module",
  "engines": {
    "node": ">=22.19.0",
    "npm": ">=10.9.0"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "tsx --conditions source --test \"src/**/*.test.ts\""
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "l10n-android-diff-keys": "dist/diff-keys-cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "domhandler": "^6.0.1",
    "domutils": "^4.0.2",
    "fast-xml-parser": "^5.7.1",
    "he": "^1.2.0",
    "htmlparser2": "^12.0.0",
    "npmlog": "^7.0.1"
  },
  "devDependencies": {
    "@types/he": "^1.2.3",
    "@types/npmlog": "^7.0.0"
  },
  "peerDependencies": {
    "l10n-tools-core": "^7.9.1"
  },
  "author": "Eungkyu Song <eungkyu@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tpcint/l10n-tools.git",
    "directory": "packages/plugin-android"
  }
}
