{
  "name": "l10n-tools-syncer-l10n-storage",
  "version": "1.2.0",
  "description": "l10n-tools syncer for tpc-agent l10n-storage service",
  "type": "module",
  "engines": {
    "node": ">=22.19.0",
    "npm": ">=10.9.0"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "tsx --conditions source --test \"src/*.test.ts\"",
    "test:e2e": "tsx --env-file-if-exists=.env --conditions source --test \"src/e2e/*.e2e.test.ts\""
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "es-toolkit": "^1.46.1",
    "npmlog": "^7.0.1"
  },
  "devDependencies": {
    "@types/npmlog": "^7.0.0"
  },
  "peerDependencies": {
    "l10n-tools-core": "^8.0.0"
  },
  "author": "Eungkyu Song <eungkyu@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tpcint/l10n-tools.git",
    "directory": "packages/syncer-l10n-storage"
  }
}
